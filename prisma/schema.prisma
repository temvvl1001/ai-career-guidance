generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  password      String
  name          String?
  image         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  accounts      Account[]
  AiChatMessage AiChatMessage[]
  skillResults  SkillResult[]
  testResults   TestResult[]
}

model TestResult {
  id        String   @id @default(uuid())
  userId    String
  mbtiType  String
  answers   Json
  scores    Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SkillResult {
  id        String   @id @default(uuid())
  userId    String
  career    String
  score     Int
  answers   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Career {
  id               String   @id
  name             String
  description      String
  salary           String
  demandLevel      String
  requiredSkills   String[]
  futureDemand     String
  createdAt        DateTime @default(now())
  nameMn           String?
  descriptionMn    String?
  futureDemandMn   String?
  requiredSkillsMn String[]
  salaryMn         String?
  demandLevelMn    String?
}

model MBTICareerMap {
  id        String   @id @default(cuid())
  mbtiType  String   @unique
  careerIds String[]
  createdAt DateTime @default(now())
}

model AiChatMessage {
  id        String   @id
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
